{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Lumina",
  "version": "4.10.0",
  "identifier": "com.lumina.spatial-studio",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lumina Spatial Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "decorations": false,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}